{
  "name": "@tachui/demos",
  "version": "0.8.8-alpha",
  "description": "Demo applications showcasing tachUI framework capabilities",
  "private": true,
  "type": "module",
  "license": "MPL-2.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "preview": "pnpm -r --parallel preview",
    "test": "pnpm -r test",
    "lint": "oxlint . --ignore-pattern='**/node_modules/**' --ignore-pattern='**/dist/**'",
    "lint:fix": "oxlint . --ignore-pattern='**/node_modules/**' --ignore-pattern='**/dist/**' --fix",
    "type-check": "pnpm -r type-check",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "intro:dev": "pnpm --filter @tachui/intro-app dev",
    "intro:build": "pnpm --filter @tachui/intro-app build",
    "intro:preview": "pnpm --filter @tachui/intro-app preview",
    "calculator:dev": "pnpm --filter @tachui/calculator-app dev",
    "calculator:build": "pnpm --filter @tachui/calculator-app build",
    "calculator:preview": "pnpm --filter @tachui/calculator-app preview",
    "setup": "pnpm install && pnpm build",
    "start": "pnpm dev"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "lint-staged": "^15.2.0",
    "oxlint": "^1.12.0",
    "prettier": "^3.2.0",
    "simple-git-hooks": "^2.9.0",
    "typescript": "^5.8.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "pre-push": "pnpm type-check && pnpm build"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "oxlint --fix"
    ],
    "*.{js,ts,tsx,json,md}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "keywords": [
    "tachui",
    "demos",
    "examples",
    "swiftui",
    "reactive",
    "web-framework"
  ],
  "author": "tachUI Team",
  "repository": {
    "type": "git",
    "url": "https://github.com/tachui/demos"
  },
  "homepage": "https://github.com/tachui/demos"
}
