{
  "name": "@tachui/calculator-app",
  "version": "0.1.0",
  "description": "tachUI Calculator - Comprehensive demo showcasing precise interaction patterns and styling",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:clean": "rm -rf node_modules/.vite* &&vite",
    "build": "vite build",
    "build:optimized": "vite build && node scripts/generate-optimized-bundle.js",
    "preview": "vite preview",
    "analyze": "npx vite-bundle-analyzer dist/stats.html",
    "bundle:analyze": "node scripts/analyze-bundle.js",
    "bundle:generate": "node scripts/generate-optimized-bundle.js",
    "test:epic-pico": "npx tsx test-epic-pico.ts",
    "epic-pico": "./build-and-test-epic-pico.sh",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite*"
  },
  "dependencies": {
    "@tachui/core": "^0.7.0-alpha1"
  },
  "devDependencies": {
    "@types/node": "^20.19.10",
    "typescript": "^5.8.0",
    "vite": "^7.1.1",
    "vite-bundle-analyzer": "^0.11.0",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "tachui",
    "calculator",
    "demo",
    "swiftui",
    "reactive"
  ],
  "author": "tachUI Team",
  "license": "MPL-2.0",
  "homepage": "https://github.com/tachui/calculator-demo",
  "repository": {
    "type": "git",
    "url": "https://github.com/tachui/demos",
    "directory": "calculator"
  }
}
